<Window x:Class="RecipePlanner.Views.AddRecipeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rezept"
        Height="500"
        Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Grid Margin="{StaticResource SpacingLarge}">

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Scrollbarer Inhalt -->
        <ScrollViewer Grid.Row="0" 
                      VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- URL Import -->
                    <RowDefinition Height="Auto"/>  <!-- Name -->
                    <RowDefinition Height="Auto"/>  <!-- Zutaten -->
                    <RowDefinition Height="*"/>     <!-- Schritte -->
                    <RowDefinition Height="Auto"/>  <!-- Quelle -->
                    <RowDefinition Height="Auto"/>  <!-- Portionen -->
                    <RowDefinition Height="Auto"/>  <!-- Tags -->
                </Grid.RowDefinitions>
                
                <!-- URL Import -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
                    <Button x:Name="ImportFromUrlButton"
                            Content="🌐 Aus URL importieren"
                            Click="ImportFromUrlButton_Click"
                            HorizontalAlignment="Left"/>
                </StackPanel>

                <!-- Name -->
                <StackPanel Grid.Row="1">
                    <TextBlock Text="Name:" 
                               Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="NameTextBox"/>
                </StackPanel>

                <!-- Zutaten -->
                <StackPanel Grid.Row="2">
                    <TextBlock Text="Zutaten (eine pro Zeile):" 
                               Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="IngredientsTextBox"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Schritte -->
                <StackPanel Grid.Row="3">
                    <TextBlock Text="Schritte (einer pro Zeile):" 
                               Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="StepsTextBox"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Quelle -->
                <StackPanel Grid.Row="4">
                    <TextBlock Text="Quelle:" 
                               Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="SourceTextBox"/>
                </StackPanel>

                <!-- Portionen -->
                <StackPanel Grid.Row="5">
                    <TextBlock Text="Portionen:"
                               Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="ServingsTextBox"
                             Text="4"/>
                </StackPanel>
                
                <!-- Tags -->
                <StackPanel Grid.Row="6">
                    <TextBlock Text="Tags (kommagetrennt):"
                               Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="TagsTextBox"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="{StaticResource SpacingTopLarge}">

            <Button Content="Abbrechen"
                    Width="100"
                    Margin="0,0,10,0"
                    IsCancel="True"
                    Style="{StaticResource SecondaryButtonStyle}"/>

            <Button Content="Speichern"
                    Width="100"
                    Click="SaveButton_Click"
                    IsDefault="True"/>
        </StackPanel>

    </Grid>
</Window>
