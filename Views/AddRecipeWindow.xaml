<Window x:Class="RecipePlanner.AddRecipeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rezept"
        Height="500"
        Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Scrollbarer Inhalt -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Name -->
                <TextBlock Text="Name:" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="NameTextBox" Margin="0,0,0,10"/>

                <!-- Zutaten -->
                <TextBlock Text="Zutaten (kommagetrennt):" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="IngredientsTextBox"
                         Margin="0,0,0,10"
                         Height="60"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"/>

                <!-- Schritte -->
                <TextBlock Text="Zubereitungsschritte (je Zeile ein Schritt):"
                           Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="StepsTextBox"
                         Margin="0,0,0,10"
                         Height="150"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"/>

                <!-- Quelle -->
                <TextBlock Text="Quelle:" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="SourceTextBox"/>

            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,15,0,0">

            <Button Content="Abbrechen"
                    Width="100"
                    Margin="0,0,10,0"
                    IsCancel="True"/>

            <Button Content="Speichern"
                    Width="100"
                    Click="SaveButton_Click"
                    IsDefault="True"/>
        </StackPanel>

    </Grid>
</Window>
