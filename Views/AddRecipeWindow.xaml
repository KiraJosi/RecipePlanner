<Window x:Class="RecipePlanner.AddRecipeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rezept"
        Height="500"
        Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Grid Margin="{StaticResource SpacingLarge}">

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Scrollbarer Inhalt -->
        <ScrollViewer Grid.Row="0" 
                      VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Name -->
                <StackPanel Grid.Row="0">
                    <TextBlock Text="Name:" 
                               Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="NameTextBox"/>
                </StackPanel>

                <!-- Zutaten -->
                <StackPanel Grid.Row="1">
                    <TextBlock Text="Zutaten:" 
                               Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="IngredientsTextBox"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Schritte -->
                <StackPanel Grid.Row="2">
                    <TextBlock Text="Schritte:" 
                               Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="StepsTextBox"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Quelle -->
                <StackPanel Grid.Row="3">
                    <TextBlock Text="Quelle:" 
                               Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="SourceTextBox"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="{StaticResource SpacingTopLarge}">

            <Button Content="Abbrechen"
                    Width="100"
                    Margin="0,0,10,0"
                    IsCancel="True"
                    Style="{StaticResource SecondaryButtonStyle}"/>

            <Button Content="Speichern"
                    Width="100"
                    Click="SaveButton_Click"
                    IsDefault="True"/>
        </StackPanel>

    </Grid>
</Window>
