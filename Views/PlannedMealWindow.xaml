<Window x:Class="RecipePlanner.PlannedMealWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mahlzeit planen"
        Height="300"
        Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Grid Margin="{StaticResource SpacingLarge}">

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Inhalt -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Datum -->
            <StackPanel Grid.Row="0">
                <TextBlock Text="Datum:"
                           FontWeight="SemiBold"
                           Margin="{StaticResource SpacingBottomSmall}"/>
            </StackPanel>
            <StackPanel Grid.Row="1">
                <DatePicker x:Name="DatePicker"
                            Margin="0,0,0,15"/>
            </StackPanel>

            <!-- Rezept -->
            <StackPanel Grid.Row="2">
                <TextBlock Text="Rezept auswählen:"
                           FontWeight="SemiBold"
                           Margin="{StaticResource SpacingBottomSmall}"/>
            </StackPanel>
            <StackPanel Grid.Row="3">
                <ComboBox x:Name="RecipeComboBox"
                          DisplayMemberPath="Name"
                          Margin="{StaticResource SpacingBottomMedium}"
                          IsEditable="False"/>
            </StackPanel>

        </Grid>

        <!-- Buttons -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="{StaticResource SpacingTopLarge}">

            <Button Content="Abbrechen"
                    Width="100"
                    Margin="0,0,10,0"
                    IsCancel="True"
                    Style="{StaticResource SecondaryButtonStyle}"/>

            <Button Content="OK"
                    Width="100"
                    Margin="0,0,10,0"
                    IsDefault="True"
                    Click="OkButton_Click"/>
        </StackPanel>

    </Grid>
</Window>

