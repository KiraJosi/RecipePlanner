<Window x:Class="RecipePlanner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RecipePlanner"
        WindowState="Maximized"  
        Height="600"
        MinHeight="600"
        Width="900"
        MinWidth="900">

    <Grid Margin="{StaticResource SpacingMedium}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <!-- Hauptinhalt -->
            <RowDefinition Height="Auto" />
            <!-- Buttons unten -->
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>

        <!-- Linke Spalte -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <!-- Rezeptliste -->
                <RowDefinition Height="*" />
                <!-- Vorrat / Zutaten -->
            </Grid.RowDefinitions>

            <!-- Rezeptliste -->
            <GroupBox Grid.Row="0" 
                      MinHeight="150">
                <GroupBox.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🍲" 
                                   Margin="0,0,5,0"/>
                        <TextBlock Text="Rezepte"
                                   Style="{StaticResource GroupHeaderTextStyle}"/>
                    </StackPanel>
                </GroupBox.Header>
                <ListBox ItemsSource="{Binding RecipesView}" 
                         SelectedItem="{Binding SelectedRecipe}"
                         Margin="{StaticResource SpacingTopSmall}">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="Recipe_PreviewMouseLeftButtonDown"/>
                            <EventSetter Event="PreviewMouseMove" Handler="Recipe_MouseMove"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" 
                                       FontSize="14"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </GroupBox>

            <!-- Vorrat / Zutaten -->
            <GroupBox Grid.Row="1" 
                      MinHeight="150">
                <GroupBox.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🥫" 
                                   Margin="0,0,5,0"/>
                        <TextBlock Text="Vorrat / Zutaten" 
                                   Style="{StaticResource GroupHeaderTextStyle}"/>
                    </StackPanel>
                </GroupBox.Header>
                <Grid Margin="{StaticResource SpacingSmall}">

                    <!-- 2 Spalten -->
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*" />
                        <ColumnDefinition Width="10" />
                        <!-- Liste -->
                        <ColumnDefinition Width="Auto" />
                        <!-- Buttons -->
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Eingabe -->
                        <RowDefinition Height="*"/>
                        <!-- Liste -->
                    </Grid.RowDefinitions>

                    <!-- Eingabe -->
                    <StackPanel Grid.Row="0" 
                                Grid.Column="0">
                        <TextBlock Text="Zutaten eingeben (kommagetrennt):"
                                   Style="{StaticResource LabelStyle}"/>
                        <TextBox Text="{Binding NewPantryText, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <!-- Vorratsliste -->
                    <ListBox Grid.Row="1"
                             Grid.Column="0"
                             ItemsSource="{Binding PantryItems}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" 
                                           FontSize="13"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Buttons -->
                    <StackPanel Grid.Row="0"
                                Grid.RowSpan="2"
                                Grid.Column="2"
                                Orientation="Vertical"
                                HorizontalAlignment="Right">

                        <Button Content="💾"
                                Command="{Binding SavePantryCommand}"
                                Margin="{StaticResource SpacingBottomSmall}"
                                ToolTip="{StaticResource TT_SavePantry}"/>

                        <Button Content="✏"
                                Command="{Binding EditPantryCommand}"
                                Margin="{StaticResource SpacingBottomSmall}"
                                ToolTip="{StaticResource TT_EditPantry}"/>

                        <Button Content="🗑"
                                Command="{Binding DeletePantryCommand}"
                                Margin="{StaticResource SpacingBottomMedium}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                ToolTip="{StaticResource TT_DeletePantry}"/>

                        <Separator Margin="0,5"/>

                        <Button Content="Rezepte finden"
                                Command="{Binding FindRecipesCommand}"
                                Margin="0,5,0,5"/>

                        <Button Content="Alle Rezepte anzeigen"
                                Command="{Binding ShowAllRecipesCommand}"
                                Margin="0,5,0,5"/>
                    </StackPanel>

                </Grid>
            </GroupBox>

        </Grid>

        <!-- Rechte Spalte -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <!-- Details -->
                <RowDefinition Height="*" />
                <!-- Kochplan -->
            </Grid.RowDefinitions>

            <!-- Rezeptdetails -->
            <GroupBox Grid.Row="0" 
                      MinHeight="200">
                <GroupBox.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📋" 
                                   Margin="0,0,5,0"/>
                        <TextBlock Text="Details"
                                   Style="{StaticResource GroupHeaderTextStyle}"/>
                    </StackPanel>
                </GroupBox.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <!-- Scrollbarer Inhalt -->
                        <RowDefinition Height="Auto"/>
                        <!-- Buttons -->
                    </Grid.RowDefinitions>

                    <!-- Scrollbarer Bereich -->
                    <ScrollViewer Grid.Row="0" 
                                  VerticalScrollBarVisibility="Auto" 
                                  HorizontalScrollBarVisibility="Disabled"
                                  CanContentScroll="True"
                                  Margin="{StaticResource SpacingBottomSmall}">
                        <StackPanel>
                            <TextBlock Text="{Binding SelectedRecipe.Name}" 
                                       FontWeight="Bold" 
                                       FontSize="18" 
                                       Margin="{StaticResource SpacingBottomMedium}"/>  

                            <!-- Zutaten -->
                            <TextBlock Text="Zutaten:" 
                                       FontWeight="SemiBold" 
                                       Margin="{StaticResource SpacingBottomSmall}"/>
                            <ItemsControl ItemsSource="{Binding SelectedRecipe.Ingredients}" 
                                          Margin="10,0,0,10">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Margin="0,0,0,2">
                                            <Run Text="• "/>
                                            <Run Text="{Binding Path=.}"/>
                                        </TextBlock>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Zubereitung -->
                            <TextBlock Text="Zubereitung:" 
                                       FontWeight="SemiBold" 
                                       Margin="{StaticResource SpacingBottomSmall}"/>
                            <ItemsControl ItemsSource="{Binding SelectedRecipe.Steps}" 
                                          Margin="10,0,0,10">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Margin="0,0,0,2">
                                            <Run Text="• "/>
                                            <Run Text="{Binding Path=.}"/>                 
                                        </TextBlock>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Quelle -->
                            <TextBlock Text="{Binding SelectedRecipe.Source}" 
                                       FontStyle="Italic" 
                                       Margin="{StaticResource SpacingTopSmall}"/>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" 
                                HorizontalAlignment="Right" 
                                Grid.Row="1">
                        <StackPanel Margin="0,0,5,0">
                            <Button Content="✏" 
                                    Command="{Binding EditRecipeCommand}" 
                                    Margin="0,0,0,2"
                                    ToolTip="{StaticResource TT_EditRecipe}"/>
                            <Button Content="🗑" 
                                    Command="{Binding DeleteRecipeCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="0,0,0,2"
                                    ToolTip="{StaticResource TT_DeleteRecipe}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <!-- Kochplan -->
            <GroupBox Grid.Row="1" 
                      MinHeight="150">
                <GroupBox.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🗓"
                                   Margin="0,0,5,0"/>
                        <TextBlock Text="Kochplan"
                                   Style="{StaticResource GroupHeaderTextStyle}"/>
                    </StackPanel>
                </GroupBox.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <!-- ListBox -->
                        <RowDefinition Height="Auto"/>
                        <!-- Buttons -->
                    </Grid.RowDefinitions>

                    <!-- ListBox -->
                    <ListBox Grid.Row="0" 
                             ItemsSource="{Binding PlannedMealsView}" 
                             SelectedItem="{Binding SelectedPlannedMeal}" 
                             AllowDrop="True"
                             Drop="Day_Drop"
                             Margin="{StaticResource SpacingBottomSmall}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Margin="0,0,0,2" 
                                           Text="{Binding DisplayText}" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}"
                                                   FontWeight="Bold"
                                                   FontSize="14"/>
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </ListBox.GroupStyle>
                    </ListBox>

                    <!-- Buttons -->
                    <StackPanel Grid.Row="1" 
                                Orientation="Horizontal" 
                                HorizontalAlignment="Right">
                        <Button Content="➕" 
                                Command="{Binding PlanRecipeCommand}"
                                ToolTip="{StaticResource TT_PlanRecipe}"/>
                        <Button Content="✏" 
                                Command="{Binding EditPlannedMealCommand}" 
                                ToolTip="{StaticResource TT_EditPlannedMeal}"/>
                        <Button Content="🗑" 
                                Command="{Binding DeletePlannedMealCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                ToolTip="{StaticResource TT_DeletePlannedMeal}"/>
                    </StackPanel>
                </Grid>
            </GroupBox>
        </Grid>

        <!-- Buttons -->
        <Border Grid.Row="1" 
                Grid.ColumnSpan="2" 
                BorderThickness="0,1,0,0" 
                BorderBrush="LightGray" 
                Padding="{StaticResource SpacingSmall}">
            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Right">
                <Button Content="➕" 
                        Command="{Binding AddRecipeCommand}"
                        ToolTip="{StaticResource TT_AddRecipe}" Cursor="Hand"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
