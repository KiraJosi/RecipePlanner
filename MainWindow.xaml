<Window x:Class="RecipePlanner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:RecipePlanner.Helpers"
        Title="RecipePlanner"
        WindowState="Maximized"  
        Height="600"
        MinHeight="600"
        Width="900"
        MinWidth="900">

    <Window.Resources>
        <helpers:DayFilterConverter x:Key="DayFilterConverter"/>
        <helpers:IsTodayConverter x:Key="IsTodayConverter"/>
    </Window.Resources>

    <Grid Margin="{StaticResource SpacingMedium}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <!-- Hauptinhalt -->
            <RowDefinition Height="Auto" />
            <!-- Buttons unten -->
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>

        <!-- Linke Spalte -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <!-- Rezeptliste -->
                <RowDefinition Height="*" />
                <!-- Vorrat / Zutaten -->
            </Grid.RowDefinitions>

            <!-- Rezeptliste -->
            <GroupBox Grid.Row="0" 
                      MinHeight="150">
                <GroupBox.Header>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🍲" 
                                   Margin="0,0,5,0"/>
                        <TextBlock Text="Rezepte"
                                   Style="{StaticResource GroupHeaderTextStyle}"/>
                        </StackPanel>
                        <TextBox Width=" 160"
                                 HorizontalAlignment="Left"
                                 Text="{Binding Recipes.SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,4,0,0"/>
                    </StackPanel>
                </GroupBox.Header>
                <ListBox ItemsSource="{Binding Recipes.RecipesView}" 
                         SelectedItem="{Binding Recipes.SelectedRecipe}"
                         Margin="{StaticResource SpacingTopSmall}">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="Recipe_PreviewMouseLeftButtonDown"/>
                            <EventSetter Event="PreviewMouseMove" Handler="Recipe_MouseMove"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" 
                                       FontSize="14"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </GroupBox>

            <!-- Vorrat / Zutaten -->
            <GroupBox Grid.Row="1" 
                      MinHeight="150">
                <GroupBox.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🥫" 
                                   Margin="0,0,5,0"/>
                        <TextBlock Text="Vorrat / Zutaten" 
                                   Style="{StaticResource GroupHeaderTextStyle}"/>
                    </StackPanel>
                </GroupBox.Header>
                <Grid Margin="{StaticResource SpacingSmall}">

                    <!-- 2 Spalten -->
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*" />
                        <ColumnDefinition Width="10" />
                        <!-- Liste -->
                        <ColumnDefinition Width="Auto" />
                        <!-- Buttons -->
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Eingabe -->
                        <RowDefinition Height="*"/>
                        <!-- Liste -->
                    </Grid.RowDefinitions>

                    <!-- Eingabe -->
                    <StackPanel Grid.Row="0" 
                                Grid.Column="0">
                        <TextBlock Text="Zutaten eingeben (kommagetrennt):"
                                   Style="{StaticResource LabelStyle}"/>
                        <TextBox Text="{Binding Pantry.NewPantryText, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <!-- Vorratsliste -->
                    <ListBox Grid.Row="1"
                             Grid.Column="0"
                             ItemsSource="{Binding Pantry.PantryItems}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" 
                                           FontSize="13"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Buttons -->
                    <StackPanel Grid.Row="0"
                                Grid.RowSpan="2"
                                Grid.Column="2"
                                Orientation="Vertical"
                                HorizontalAlignment="Right">

                        <Button Content="💾"
                                Command="{Binding Pantry.SavePantryCommand}"
                                Margin="{StaticResource SpacingBottomSmall}"
                                ToolTip="{StaticResource TT_SavePantry}"/>

                        <Button Content="✏"
                                Command="{Binding Pantry.EditPantryCommand}"
                                Margin="{StaticResource SpacingBottomSmall}"
                                ToolTip="{StaticResource TT_EditPantry}"/>

                        <Button Content="🗑"
                                Command="{Binding Pantry.DeletePantryCommand}"
                                Margin="{StaticResource SpacingBottomMedium}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                ToolTip="{StaticResource TT_DeletePantry}"/>

                        <Separator Margin="0,5"/>

                        <Button Content="Rezepte finden"
                                Command="{Binding Recipes.FindRecipesCommand}"
                                Margin="0,5,0,5"/>

                        <Button Content="Alle Rezepte anzeigen"
                                Command="{Binding Recipes.ShowAllRecipesCommand}"
                                Margin="0,5,0,5"/>
                    </StackPanel>

                </Grid>
            </GroupBox>

        </Grid>

        <!-- Rechte Spalte -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <!-- Details -->
                <RowDefinition Height="*" />
                <!-- Kochplan -->
            </Grid.RowDefinitions>

            <!-- Rezeptdetails -->
            <GroupBox Grid.Row="0" 
                      MinHeight="200">
                <GroupBox.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📋" 
                                   Margin="0,0,5,0"/>
                        <TextBlock Text="Details"
                                   Style="{StaticResource GroupHeaderTextStyle}"/>
                    </StackPanel>
                </GroupBox.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <!-- Scrollbarer Inhalt -->
                        <RowDefinition Height="Auto"/>
                        <!-- Buttons -->
                    </Grid.RowDefinitions>

                    <!-- Scrollbarer Bereich -->
                    <ScrollViewer Grid.Row="0" 
                                  VerticalScrollBarVisibility="Auto" 
                                  HorizontalScrollBarVisibility="Disabled"
                                  CanContentScroll="True"
                                  Margin="{StaticResource SpacingBottomSmall}">
                        <StackPanel>
                            <TextBlock Text="{Binding Recipes.SelectedRecipe.Name}" 
                                       FontWeight="Bold" 
                                       FontSize="18" 
                                       Margin="{StaticResource SpacingBottomMedium}"/>  

                            <!-- Zutaten -->
                            <TextBlock Text="Zutaten:" 
                                       FontWeight="SemiBold" 
                                       Margin="{StaticResource SpacingBottomSmall}"/>
                            <ItemsControl ItemsSource="{Binding Recipes.SelectedRecipe.Ingredients}" 
                                          Margin="10,0,0,10">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Margin="0,0,0,2">
                                            <Run Text="• "/>
                                            <Run Text="{Binding Path=.}"/>
                                        </TextBlock>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Zubereitung -->
                            <TextBlock Text="Zubereitung:" 
                                       FontWeight="SemiBold" 
                                       Margin="{StaticResource SpacingBottomSmall}"/>
                            <ItemsControl ItemsSource="{Binding Recipes.SelectedRecipe.Steps}" 
                                          Margin="10,0,0,10">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Margin="0,0,0,2">
                                            <Run Text="• "/>
                                            <Run Text="{Binding Path=.}"/>                 
                                        </TextBlock>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Quelle -->
                            <TextBlock Text="{Binding Recipes.SelectedRecipe.Source}" 
                                       FontStyle="Italic" 
                                       Margin="{StaticResource SpacingTopSmall}"/>
                            
                            <!-- Tags -->
                            <ItemsControl ItemsSource="{Binding Recipes.SelectedRecipe.Tags}"
                                          Margin="0,5,0,0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource PrimaryBrush}"
                                                CornerRadius="4"
                                                Padding="6,2"
                                                Margin="0,0,4,4">
                                            <TextBlock Text="{Binding}"
                                                       Foreground="White"
                                                       FontSize="11"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" 
                                HorizontalAlignment="Right" 
                                Grid.Row="1">
                        <StackPanel Margin="0,0,5,0">
                            <Button Content="✏" 
                                    Command="{Binding Recipes.EditRecipeCommand}" 
                                    Margin="0,0,0,2"
                                    ToolTip="{StaticResource TT_EditRecipe}"/>
                            <Button Content="🗑" 
                                    Command="{Binding Recipes.DeleteRecipeCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="0,0,0,2"
                                    ToolTip="{StaticResource TT_DeleteRecipe}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <!-- Kochplan -->
            <GroupBox Grid.Row="1" 
                      MinHeight="150">
                <GroupBox.Header>
                        <TextBlock Text="🗓 Wochenansicht"
                                   Margin="0,0,5,0"/>
                </GroupBox.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Navigation -->
                        <RowDefinition Height="*"/>
                        <!-- ListBox -->
                        <RowDefinition Height="Auto"/>
                        <!-- Buttons -->
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0" Grid.ColumnSpan="7"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,5">
                        <Button Content="◀" Width="30"
                                Command="{Binding MealPlan.PreviousWeekCommand}"/>
                        <TextBlock VerticalAlignment="Center" Margin="10,0"
                                   FontWeight="SemiBold"
                                   Text="{Binding MealPlan.CurrentWeek[0], StringFormat=KW ab dd.MM.yyyy}"/>
                        <Button Content="▶" Width="30"
                                Command="{Binding MealPlan.NextWeekCommand}"/>

                    </StackPanel>

                    <ListBox Grid.Row="1" Grid.ColumnSpan="7"
                             ItemsSource="{Binding MealPlan.CurrentWeek}"
                             HorizontalContentAlignment="Stretch"
                             BorderThickness="0"
                             Background="Transparent">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="7"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <ContentPresenter/>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel AllowDrop="True"
                                            Drop="Day_Drop"
                                            Margin="2">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Date, Converter={StaticResource IsTodayConverter}}" Value="True">
                                                    <Setter Property="Background" Value="#1A0078D4"/>
                                                    <Setter Property="TextElement.FontWeight" Value="Bold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    
                                    <TextBlock Text="{Binding Date, StringFormat=ddd dd.MM.}"
                                               FontWeight="Bold"
                                               Margin="0,0,0,5"/>
                                    <ListBox ItemsSource="{Binding DataContext.MealPlan.PlannedMeals,
                                             RelativeSource={RelativeSource AncestorType=Window}}"
                                             SelectedItem="{Binding DataContext.MealPlan.SelectedPlannedMeal,
                                             RelativeSource={RelativeSource AncestorType=Window}}"
                                             BorderThickness="0"
                                             Background="Transparent">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Padding" Value="2"/>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Recipe.Name}">
                                                    <TextBlock.Visibility>
                                                        <MultiBinding Converter="{StaticResource DayFilterConverter}">
                                                            <Binding Path="."/>
                                                            <Binding Path="Date"
                                                                     RelativeSource="{RelativeSource AncestorType=StackPanel}"/>
                                                        </MultiBinding>
                                                    </TextBlock.Visibility>
                                                </TextBlock>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    
                    <!-- Buttons -->
                    <StackPanel Grid.Row="2" 
                                Orientation="Horizontal" 
                                HorizontalAlignment="Right">
                        <Button Content="🛒"
                                Command="{Binding MealPlan.GenerateShoppingListCommand}"
                                ToolTip="{StaticResource TT_ShoppingList}"/>
                        <Button Content="➕" 
                                Command="{Binding MealPlan.PlanRecipeCommand}"
                                ToolTip="{StaticResource TT_PlanRecipe}"/>
                        <Button Content="✏" 
                                Command="{Binding MealPlan.EditPlannedMealCommand}" 
                                ToolTip="{StaticResource TT_EditPlannedMeal}"/>
                        <Button Content="🗑" 
                                Command="{Binding MealPlan.DeletePlannedMealCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                ToolTip="{StaticResource TT_DeletePlannedMeal}"/>
                    </StackPanel>
                </Grid>
            </GroupBox>
        </Grid>

        <!-- Buttons -->
        <Border Grid.Row="1" 
                Grid.ColumnSpan="2" 
                BorderThickness="0,1,0,0" 
                BorderBrush="LightGray" 
                Padding="{StaticResource SpacingSmall}">
            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Right">
                <Button Content="➕" 
                        Command="{Binding Recipes.AddRecipeCommand}"
                        ToolTip="{StaticResource TT_AddRecipe}" Cursor="Hand"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
